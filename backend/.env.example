# Example environment variables for backend
# Copy this file to `.env` and set real values before running the server

# MongoDB connection string. For example (Atlas):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/mydatabase?retryWrites=true&w=majority
MONGO_URI=

# JWT secret used to sign tokens
JWT_SECRET=your_jwt_secret_here

# Server port (optional)
PORT=5000
